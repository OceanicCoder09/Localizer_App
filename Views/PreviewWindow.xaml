<Window x:Class="Localizer_App.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Localization Preview — Design Studio"
        Height="640" Width="960"
        MinHeight="520" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#E8E8E8">

    <Window.Resources>
        <Style x:Key="PreviewMenuItem" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewToolButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter Property="BorderBrush" Value="#0696D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewPrimaryButton" TargetType="Button" BasedOn="{StaticResource PreviewActionButton}">
            <Setter Property="Background" Value="#0696D7"/>
        </Style>

        <Style x:Key="PreviewSecondaryButton" TargetType="Button" BasedOn="{StaticResource PreviewActionButton}">
            <Setter Property="Background" Value="#6B6B6B"/>
        </Style>

        <Style x:Key="PreviewOutlineButton" TargetType="Button" BasedOn="{StaticResource PreviewActionButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title / Language bar -->
        <Border Grid.Row="0" Background="#2B2B2B" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#0696D7" Width="4" Height="22" Margin="0,0,10,0"/>
                    <TextBlock Text="Design Studio" Foreground="White" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="  —  Localization Preview" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Language:" Foreground="#CCCCCC" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="LanguageCombo"
                              SelectionChanged="OnLanguageSelectionChanged"
                              Width="140"
                              FontSize="11"/>
                    <Button Content="↻" ToolTip="Reload RC resources"
                            Click="OnReloadClick"
                            Width="28" Height="28" Margin="8,0,0,0"
                            Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Menu bar -->
        <Border Grid.Row="1" Background="#3C3C3C" BorderBrush="#252526" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource PreviewMenuItem}" Text="{Binding SupplyText}"/>
                <TextBlock Style="{StaticResource PreviewMenuItem}" Text="{Binding UpheavalText}"/>
                <TextBlock Style="{StaticResource PreviewMenuItem}" Text="{Binding VeryText}"/>
                <TextBlock Style="{StaticResource PreviewMenuItem}" Text="{Binding SadlyText}"/>
                <TextBlock Style="{StaticResource PreviewMenuItem}" Text="{Binding NowText}"/>
                <TextBlock Style="{StaticResource PreviewMenuItem}" Text="{Binding AutoText}"/>
            </StackPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PreviewToolButton}" Content="{Binding NewProjectTool}"/>
                <Button Style="{StaticResource PreviewToolButton}" Content="{Binding OpenTool}"/>
                <Button Style="{StaticResource PreviewToolButton}" Content="{Binding SaveTool}"/>
                <Button Style="{StaticResource PreviewToolButton}" Content="{Binding ExportTool}"/>
            </StackPanel>
        </Border>

        <!-- Main content + Properties panel -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Drawing viewport placeholder -->
            <Border Grid.Column="0" Background="#FFFFFF" Margin="8" BorderBrush="#D0D0D0" BorderThickness="1">
                <Grid>
                    <Rectangle Fill="#FAFAFA"/>
                    <Canvas>
                        <Line X1="40" Y1="40" X2="400" Y2="280" Stroke="#DDDDDD" StrokeThickness="1"/>
                        <Line X1="40" Y1="280" X2="400" Y2="40" Stroke="#DDDDDD" StrokeThickness="1"/>
                        <Ellipse Canvas.Left="120" Canvas.Top="80" Width="200" Height="160"
                                 Stroke="#0696D7" StrokeThickness="2" Fill="#E8F4FC" Opacity="0.6"/>
                    </Canvas>
                    <TextBlock Text="Drawing View" Foreground="#BBBBBB" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Properties panel -->
            <Border Grid.Column="1" Background="#FFFFFF" Margin="0,8,8,8"
                    BorderBrush="#D0D0D0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="10,8">
                        <TextBlock Text="{Binding PropertiesTitle}" Foreground="#333333" FontWeight="SemiBold" FontSize="12"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="12,10">
                        <TextBlock Text="{Binding NameLabel}" Foreground="#666666" FontSize="10" Margin="0,0,0,3"/>
                        <TextBox Text="Sample Part" IsReadOnly="True" Background="#FAFAFA" BorderBrush="#DDDDDD"
                                 Padding="6,4" Margin="0,0,0,12" FontSize="11"/>

                        <TextBlock Text="{Binding DescriptionLabel}" Foreground="#666666" FontSize="10" Margin="0,0,0,3"/>
                        <TextBox Text="Bracket assembly" IsReadOnly="True" Background="#FAFAFA" BorderBrush="#DDDDDD"
                                 Padding="6,4" Margin="0,0,0,12" FontSize="11"/>

                        <TextBlock Text="{Binding CategoryLabel}" Foreground="#666666" FontSize="10" Margin="0,0,0,3"/>
                        <TextBox Text="Mechanical" IsReadOnly="True" Background="#FAFAFA" BorderBrush="#DDDDDD"
                                 Padding="6,4" Margin="0,0,0,12" FontSize="11"/>

                        <TextBlock Text="{Binding StatusLabel}" Foreground="#666666" FontSize="10" Margin="0,0,0,3"/>
                        <TextBox Text="Draft" IsReadOnly="True" Background="#FAFAFA" BorderBrush="#DDDDDD"
                                 Padding="6,4" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Action buttons -->
        <Border Grid.Row="4" Background="#F5F5F5" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource PreviewPrimaryButton}" Content="{Binding SaveButton}"/>
                <Button Style="{StaticResource PreviewOutlineButton}" Content="{Binding CancelButton}"/>
                <Button Style="{StaticResource PreviewSecondaryButton}" Content="{Binding ApplyButton}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="5" Background="#0078D4" Padding="10,4">
            <TextBlock Text="{Binding ReadyStatus}" Foreground="White" FontSize="11"/>
        </Border>

        <!-- Resource loader status -->
        <Border Grid.Row="6" Background="#2B2B2B" Padding="10,5">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#AAAAAA" FontSize="10" TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
